*.pdf filter=lfs diff=lfs merge=lfs -text
*.zip filter=lfs diff=lfs merge=lfs -text
*.mp4 filter=lfs diff=lfs merge=lfs -text
*.mov filter=lfs diff=lfs merge=lfs -text
*.avi filter=lfs diff=lfs merge=lfs -text
*.mkv filter=lfs diff=lfs merge=lfs -text

# Exclude brand, team, gallery, resources images from LFS (needed for Vercel builds)
src/assets/images/brand/**/*.jpg !filter !diff !merge
src/assets/images/brand/**/*.jpeg !filter !diff !merge
src/assets/images/team/**/*.jpg !filter !diff !merge
src/assets/images/team/**/*.jpeg !filter !diff !merge
src/assets/images/gallery/**/*.jpg !filter !diff !merge
src/assets/images/gallery/**/*.jpeg !filter !diff !merge
src/assets/images/resources/**/*.jpg !filter !diff !merge
src/assets/images/resources/**/*.jpeg !filter !diff !merge
# Exclude ALL public folder images from LFS (store as regular files for Vercel)
public/images/**/*.jpg !filter !diff !merge
public/images/**/*.jpeg !filter !diff !merge
public/images/**/*.png !filter !diff !merge
public/images/**/*.gif !filter !diff !merge
public/images/**/*.webp !filter !diff !merge
public/images/**/*.svg !filter !diff !merge
src/assets/images/brand/* !text !filter !merge !diff
src/assets/images/team/* !text !filter !merge !diff
src/assets/images/gallery/* !text !filter !merge !diff
src/assets/images/resources/* !text !filter !merge !diff
