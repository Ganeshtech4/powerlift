# .env.example - Template for environment variables
# Copy this to .env and fill in your actual values

# ========================================
# AWS Configuration
# ========================================
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here
AWS_REGION=ap-south-2
AWS_BLOG_BUCKET=your_bucket_name

# ========================================
# DynamoDB Tables
# ========================================
DYNAMODB_BLOGS_TABLE=rekha_powerlifting_blogs
DYNAMODB_DISTRICTS_TABLE=rekha_telangana_districts
DYNAMODB_RESULTS_TABLE=rekha_results
DYNAMODB_EVENTS_TABLE=rekha_events

# ========================================
# Authentication
# ========================================
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_secure_password
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ========================================
# API Configuration
# ========================================
API_V1_PREFIX=/api/v1

# ========================================
# CORS Origins (comma-separated)
# ========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# ========================================
# Image Processing
# ========================================
MAX_IMAGE_SIZE_MB=20
MAX_IMAGES_PER_BLOG=500
THUMBNAIL_WIDTH=400
THUMBNAIL_HEIGHT=300

# ========================================
# Email Configuration (Gmail SMTP)
# ========================================
# Required for contact form functionality
# Get App Password from: https://myaccount.google.com/apppasswords
MAIL_USERNAME=powerlifitingassociationofts@gmail.com
MAIL_PASSWORD=your_gmail_app_password_here
MAIL_FROM=powerlifitingassociationofts@gmail.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_FROM_NAME=WPC Telangana Contact Form
MAIL_STARTTLS=True
MAIL_SSL_TLS=False
USE_CREDENTIALS=True
VALIDATE_CERTS=True
MAIL_TO=powerlifitingassociationofts@gmail.com
