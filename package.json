{
  "name": "eventflow",
  "version": "0.1.0",
  "homepage": "/",
  "proxy": "http://127.0.0.1:8000",
  "private": true,
  "dependencies": {
    "@aws-sdk/client-s3": "^3.940.0",
    "@aws-sdk/s3-request-presigner": "^3.940.0",
    "@emailjs/browser": "^4.4.1",
    "@react-pdf/renderer": "^4.3.1",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "aws-sdk": "^2.1692.0",
    "axios": "^1.13.2",
    "bootstrap": "^5.3.3",
    "circletype": "^2.3.0",
    "core-js": "^3.38.1",
    "flipbook-vue": "^1.0.0-beta.4",
    "multer": "^2.0.2",
    "multer-s3": "^3.0.1",
    "pdfjs-dist": "^5.4.394",
    "react": "^18.3.1",
    "react-accessible-accordion": "^5.0.0",
    "react-burger-menu": "^3.0.9",
    "react-countup": "^6.5.3",
    "react-customizable-progressbar": "^2.0.0",
    "react-dom": "^18.3.1",
    "react-helmet": "^6.1.0",
    "react-icons": "^5.5.0",
    "react-mailchimp-subscribe": "^2.1.3",
    "react-modal-video": "^2.0.2",
    "react-pageflip": "^2.0.3",
    "react-pdf": "^10.2.0",
    "react-router-dom": "^6.26.2",
    "react-scripts": "5.0.1",
    "react-tabs": "^6.0.2",
    "react-visibility-sensor": "^5.1.1",
    "swiper": "^11.1.14",
    "turn.js": "^1.0.2",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "build:vercel": "CI=false npm run build"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "jest": {
    "transformIgnorePatterns": [
      "node_modules/(?!(swiper|ssr-window|dom7|react-pdf|pdfjs-dist)/)"
    ],
    "moduleNameMapper": {
      "^swiper/react$": "swiper/swiper-react.mjs",
      "^swiper/modules$": "swiper/modules/index.mjs",
      "^swiper$": "swiper/swiper.mjs",
      "^swiper/css$": "identity-obj-proxy",
      "^swiper/css/(.+)$": "identity-obj-proxy",
      "^react-pdf$": "<rootDir>/src/__mocks__/react-pdf.js",
      "\\.(css|less|scss|sass)$": "identity-obj-proxy"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@babel/plugin-transform-private-property-in-object": "^7.27.1",
    "identity-obj-proxy": "^3.0.0",
    "react-dev-utils": "^12.0.1",
    "yaml": "^2.8.4"
  },
  "overrides": {
    "nth-check": "^2.1.1",
    "postcss": "^8.4.31",
    "webpack-dev-server": "^4.15.2"
  }
}
